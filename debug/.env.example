# Debug & Monitoring Environment Configuration
# Copy to .env and adjust values

# Syslog ports
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514

# Loki API port
LOKI_PORT=3100

# Promtail metrics port (for Prometheus scraping)
PROMTAIL_METRICS_PORT=9080

# Log retention (hours)
# 168h = 7 days
# 720h = 30 days
LOG_RETENTION_HOURS=720h

# Storage limits
LOKI_INGESTION_RATE_MB=10
LOKI_INGESTION_BURST_MB=20
